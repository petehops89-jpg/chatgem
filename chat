
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body { font-family: sans-serif; margin: 0; display: flex; flex-direction: column; height: 100vh; background: #1a1a1a; color: white; }
        #chat { flex: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; background: #222; }
        .user { align-self: flex-end; background: #007bff; padding: 12px; border-radius: 15px; max-width: 80%; }
        .bot { align-self: flex-start; background: #444; padding: 12px; border-radius: 15px; max-width: 80%; }
        #controls { padding: 15px; background: #333; display: flex; gap: 10px; }
        input { flex: 1; padding: 12px; border: none; border-radius: 25px; outline: none; }
        button { background: #007bff; color: white; border: none; border-radius: 25px; padding: 0 20px; cursor: pointer; font-weight: bold; }
        #key-input { width: 100%; background: #000; color: #666; border: none; padding: 8px; font-size: 10px; text-align: center; }
    </style>
</head>
<body>
    <input type="password" id="key" placeholder="PASTE API KEY HERE">
    <div id="chat"></div>
    <div id="controls">
        <input type="text" id="userInput" placeholder="Type message...">
        <button onclick="send()">SEND</button>
    </div>

<script>
    async function send() {
        const key = document.getElementById('key').value.trim();
        const input = document.getElementById('userInput');
        const chat = document.getElementById('chat');
        const text = input.value.trim();

        if (!text || !key) { alert("Need Key and Message!"); return; }

        // Clear input and show user message immediately
        input.value = "";
        chat.innerHTML += `<div class="user">${text}</div>`;
        chat.scrollTop = chat.scrollHeight;

        try {
            // Using the v1 endpoint which is more stable for simple calls
            const url = `https://generativelanguage.googleapis.com{key}`;
            
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ contents: [{ parts: [{ text: text }] }] })
            });

            const data = await response.json();

            if (data.candidates && data.candidates[0].content) {
                const answer = data.candidates[0].content.parts[0].text;
                chat.innerHTML += `<div class="bot">${answer}</div>`;
            } else {
                const errorMsg = data.error ? data.error.message : "Check Key/Billing";
                chat.innerHTML += `<div class="bot" style="color:red">Error: ${errorMsg}</div>`;
            }
        } catch (err) {
            chat.innerHTML += `<div class="bot" style="color:red">Network Error: Browser blocked the request. Try Chrome or Mobile Data.</div>`;
            console.error(err);
        }
        chat.scrollTop = chat.scrollHeight;
    }
</script>
</body>
</html>

